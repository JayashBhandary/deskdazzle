# Copy to .env.local (gitignored) and fill in for production hardening.

# Firebase App Check — reCAPTCHA v3 site key.
# Register a reCAPTCHA v3 key in the Firebase console (App Check → apps) and
# paste the SITE key here. When set, the app attests requests so RTDB will only
# serve the real app (hardens the C-2 database rules against scripted abuse).
# Leave empty in dev; App Check is skipped when unset.
VITE_APPCHECK_SITE_KEY=
